// Prisma schema for Expense Tracker.
// Run `npx prisma migrate dev` after editing.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Transaction {
  id        String   @id @default(uuid())
  amount    Float
  category  String
  date      DateTime
  note      String?
  createdAt DateTime @default(now())

  @@index([date])
  @@index([category])
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  color     String
  createdAt DateTime @default(now())
}
