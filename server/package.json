{
  "name": "server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "src/app.js",
  "scripts": {
    "dev": "nodemon --watch src --watch prisma --ext js,prisma src/dev-server.js",
    "build": "prisma generate",
    "prisma:generate": "dotenv -e ../.env -- prisma generate",
    "prisma:migrate": "dotenv -e ../.env -- prisma migrate deploy",
    "prisma:migrate:dev": "dotenv -e ../.env -- prisma migrate dev",
    "prisma:migrate:init": "dotenv -e ../.env -- prisma migrate dev --name init",
    "prisma:push": "dotenv -e ../.env -- prisma db push",
    "prisma:studio": "dotenv -e ../.env -- prisma studio",
    "seed": "dotenv -e ../.env -- node src/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "morgan": "^1.10.0",
    "serverless-http": "^3.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.2",
    "nodemon": "^3.1.7",
    "prisma": "^5.22.0"
  }
}
