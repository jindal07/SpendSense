{
  "name": "spendsense",
  "private": true,
  "version": "1.0.0",
  "description": "SpendSense — a minimal, modern expense tracker PWA (React + Express + Neon Postgres) with INR support.",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c magenta,cyan \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "npm --workspace client run dev",
    "dev:server": "npm --workspace server run dev",
    "build": "npm --workspace client run build",
    "build:client": "npm --workspace client run build",
    "db:init": "npm --workspace server run db:init",
    "db:seed": "npm --workspace server run seed",
    "vercel-build": "npm --workspace client run build"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
