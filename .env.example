# Neon Postgres connection string
# Get this from https://console.neon.tech after creating a project.
# Must include `?sslmode=require` for Neon.
DATABASE_URL="postgresql://user:password@ep-xxxx-xxxx.region.aws.neon.tech/expense_tracker?sslmode=require"

# Optional: port for local Express server (defaults to 3001)
PORT=3001
